<div class="linear-gauge">
    <div class="gauge-bar " style="@($"width: {SuccessRate}%; background-color: {GetColor(SuccessRate)}; ")"><i class="fa fa-shield gauge-label"></i></div>
</div>

@code {
    [Parameter]
    public int SuccessRate { get; set; }

    private string GetColor(int value)
    {
        if (value == 0)
        {
            return "#FF0000"; // red
        }
        else if (value == 100)
        {
            return "#00FF00"; // green
        }
        else if (value >= 50) // green for high values
        {
            var r = (int)Math.Round((value - 50) * 5.1);
            var g = 255;
            var b = 0;
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        else // red for low values
        {
            var r = 255;
            var g = (int)Math.Round(value * 5.1);
            var b = 0;
            return $"#{r:X2}{g:X2}{b:X2}";
        }
    }

