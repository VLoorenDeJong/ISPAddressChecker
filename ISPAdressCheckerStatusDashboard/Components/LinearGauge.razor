<div class="linear-gauge">
    <div class="gauge-background"></div>
    <div class="gauge-bar" style="@($"height: {SuccessRate}%; background-color: {GetColor(SuccessRate)};")">
        <div class="gauge-label">@($"{SuccessRate}%")</div>
    </div>
</div>



@code {
    [Parameter]
    public int SuccessRate { get; set; }

    private string GetColor(int value)
    {
        if (value == 0)
        {
            return "#00FF00"; // green
        }
        else if (value == 100)
        {
            return "#FF0000"; // red
        }
        else if (value < 50)
        {
            var r = (int)Math.Round(value * 5.1);
            var g = 255;
            var b = 0;
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        else
        {
            var r = 255;
            var g = (int)Math.Round((100 - value) * 5.1);
            var b = 0;
            return $"#{r:X2}{g:X2}{b:X2}";
        }
    }

}
